{
  "name": "Genderify",
  "version": "1.0.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/drachenpapa/genderify.git"
  },
  "license": "MIT",
  "config": {
    "app_to_debug": "word",
    "app_type_to_debug": "desktop",
    "dev_server_port": 3000
  },
  "scripts": {
    "build": "npm run typecheck && webpack --mode production",
    "build:dev": "npm run typecheck && webpack --mode development",
    "dev-server": "webpack serve --mode development",
    "lint": "office-addin-lint check",
    "lint:fix": "office-addin-lint fix",
    "prettier": "office-addin-lint prettier",
    "build:office": "npm run typecheck && webpack --mode production --env target=office",
    "build:outlook": "npm run typecheck && webpack --mode production --env target=outlook",
    "signin": "office-addin-dev-settings m365-account login",
    "signout": "office-addin-dev-settings m365-account logout",
    "start": "office-addin-debugging start manifests/manifest-office.xml",
    "start:excel": "office-addin-debugging start manifests/manifest-office.xml --app Excel",
    "start:outlook": "office-addin-debugging start manifests/manifest-outlook.xml --app Outlook",
    "start:powerpoint": "office-addin-debugging start manifests/manifest-office.xml --app Powerpoint",
    "start:word": "office-addin-debugging start manifests/manifest-office.xml --app Word",
    "stop": "office-addin-debugging stop manifests/manifest-office.xml",
    "validate": "office-addin-manifest validate manifests/manifest-office.xml",
    "watch": "webpack --mode development --watch",
    "test": "jest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "core-js": "^3.42.0",
    "regenerator-runtime": "^0.14.1"
  },
  "devDependencies": {
    "@babel/core": "^7.27.1",
    "@babel/preset-typescript": "^7.27.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "@types/office-js": "^1.0.503",
    "@types/office-runtime": "^1.0.35",
    "babel-loader": "^10.0.0",
    "copy-webpack-plugin": "^14.0.0",
    "eslint-plugin-office-addins": "^4.0.3",
    "html-loader": "^5.1.0",
    "html-webpack-plugin": "^5.6.3",
    "jest": "^30.0.0",
    "jest-environment-jsdom": "^30.0.0",
    "office-addin-cli": "^2.0.3",
    "office-addin-debugging": "^6.0.3",
    "office-addin-dev-certs": "^2.0.3",
    "office-addin-lint": "^3.0.3",
    "office-addin-manifest": "^2.0.3",
    "office-addin-prettier-config": "^2.0.1",
    "ts-jest": "^29.3.4",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.0",
    "webpack": "^5.99.9",
    "webpack-cli": "^7.0.0",
    "webpack-dev-server": "5.2.4"
  },
  "prettier": "office-addin-prettier-config",
  "browserslist": [
    "last 2 versions"
  ],
  "overrides": {
    "tmp": ">=0.2.4",
    "serialize-javascript": ">=7.0.5",
    "uuid": "14.0.0",
    "protobufjs": "8.3.0",
    "@opentelemetry/sdk-node": "0.218.0",
    "@opentelemetry/otlp-transformer": "0.218.0",
    "@opentelemetry/otlp-exporter-base": "0.218.0",
    "@opentelemetry/otlp-grpc-exporter-base": "0.218.0",
    "@opentelemetry/exporter-logs-otlp-grpc": "0.218.0",
    "@opentelemetry/exporter-logs-otlp-http": "0.218.0",
    "@opentelemetry/exporter-logs-otlp-proto": "0.218.0",
    "@opentelemetry/exporter-metrics-otlp-grpc": "0.218.0",
    "@opentelemetry/exporter-metrics-otlp-http": "0.218.0",
    "@opentelemetry/exporter-metrics-otlp-proto": "0.218.0",
    "@opentelemetry/exporter-trace-otlp-grpc": "0.218.0",
    "@opentelemetry/exporter-trace-otlp-http": "0.218.0",
    "@opentelemetry/exporter-trace-otlp-proto": "0.218.0"
  }
}
